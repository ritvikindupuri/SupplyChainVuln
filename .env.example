# REQUIRED: Your Anthropic API key for Claude
# Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Elasticsearch password (optional, defaults to "packetsentry")
ELASTIC_PASSWORD=packetsentry

# Claude model to use (optional, defaults to claude-sonnet-4-6)
# See https://docs.anthropic.com/en/docs/about-claude/models
CLAUDE_MODEL=claude-sonnet-4-6

# Minimum tool calls required before Claude can declare analysis complete (optional, defaults to 3)
# Higher values force deeper investigation before the agent stops
MIN_TOOL_CALLS_FOR_COMPLETE=3
