# REQUIRED: Your Anthropic API key for Claude
# Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Claude model to use (optional, defaults to claude-sonnet-4-6)
# See https://docs.anthropic.com/en/docs/about-claude/models
CLAUDE_MODEL=claude-sonnet-4-6

# Guardrail: min tool calls before Claude can declare analysis_complete (optional, defaults to 3)
# Prevents premature "all clear" — Claude must run at least this many tshark commands
# per cycle before it's allowed to stop. 0=disabled, 1-2=quick, 3=default, 4-6=deep, 7+=extreme
MIN_TOOL_CALLS_FOR_COMPLETE=3
